{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WellBeing Companion",
  "version": "1.1.0",
  "identifier": "com.wellbeing.app",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WellBeing Companion",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "visible": false,
        "backgroundColor": "#0a0e17"
      },
      {
        "label": "popup",
        "url": "popup.html",
        "title": "WellBeing Reminder",
        "width": 392,
        "height": 148,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
