{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WellBeing",
  "version": "0.1.0",
  "identifier": "com.wellbeing.app",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WellBeing Health & Productivity Companion",
        "width": 450,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
